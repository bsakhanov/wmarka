{
  "$schema": "https://developer.joomla.org/schemas/json-schema/web_assets.json",
  "name": "wmarka",
  "version": "2.0.2",
  "assets": [
    {
      "name": "fonts",
      "type": "style",
      "uri": "media/templates/site/wmarka/css/fonts.css"
    },
    {
      "name": "uikit.min",
      "type": "style",
      "uri": "media/templates/site/wmarka/css/uikit.min.css",
      "dependencies": ["fonts"]
    }, 
    {
      "name": "user",
      "type": "style",
      "uri": "media/templates/site/wmarka/css/user.css",
      "dependencies": ["uikit.min"]
    },
    {
      "name": "uikit.min",
      "type": "script",
      "uri": "media/templates/site/wmarka/js/uikit.min.js",
      "attributes" : { "defer": true } 
    },
    {
      "name": "uikit-icons.min",
      "type": "script",
      "uri": "media/templates/site/wmarka/js/uikit-icons.min.js",
      "attributes" : { "defer": true },
      "dependencies": ["uikit.min"]
    }
  ]
}

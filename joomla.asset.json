{
  "$schema": "https://developer.joomla.org/schemas/json-schema/web_assets.json",
  "name": "wmarka",
  "version": "3.0.0",
  "description": "Wmarka template assets (Joomla 6 & UIkit 3)",
  "assets": [
    {
      "name": "fonts",
      "type": "style",
      "uri": "media/templates/site/wmarka/css/fonts.css",
      "version": "3.0.0"
    },
    {
      "name": "uikit.min",
      "type": "style",
      "uri": "media/templates/site/wmarka/css/uikit.min.css",
      "version": "3.25.4",
      "dependencies": [
        "template.wmarka.fonts"
      ]
    },
    {
      "name": "user",
      "type": "style",
      "uri": "media/templates/site/wmarka/css/user.css",
      "version": "3.0.0",
      "dependencies": [
        "template.wmarka.uikit.min"
      ]
    },
    {
      "name": "uikit.min",
      "type": "script",
      "uri": "media/templates/site/wmarka/js/uikit.min.js",
      "version": "3.25.4",
      "attributes": {
        "defer": true
      }
    },
    {
      "name": "uikit-icons.min",
      "type": "script",
      "uri": "media/templates/site/wmarka/js/uikit-icons.min.js",
      "version": "3.25.4",
      "attributes": {
        "defer": true
      },
      "dependencies": [
        "template.wmarka.uikit.min"
      ]
    },
    {
      "name": "wmarka-icons-min",
      "type": "script",
      "uri": "media/templates/site/wmarka/js/wmarka-icons-min.js",
      "version": "3.0.0",
      "attributes": {
        "defer": true
      },
      "dependencies": [
        "template.wmarka.uikit.min"
      ]
    }
  ]
}
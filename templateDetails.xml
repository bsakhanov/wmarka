<?xml version="1.0" encoding="utf-8"?>
<extension type="template" client="site" method="upgrade">
    <name>wmarka</name>
    <version>3.0.0</version>
    <creationDate>December 2025</creationDate>
    <author>Webmarka Kazakhstan</author>
    <authorEmail>support@webmarka.kz</authorEmail>
    <authorUrl>https://webmarka.kz</authorUrl>
    <copyright>Copyright (C) 2025 Webmarka. All rights reserved.</copyright>
    <license>GNU General Public License v2 or later</license>
    <description>TPL_WMARKA_XML_DESCRIPTION</description>

    <inheritable>1</inheritable>
    
    <scriptfile>script.php</scriptfile>

    <files>
        <filename>index.php</filename>
        <filename>templateDetails.xml</filename>
        <filename>joomla.asset.json</filename>
        <filename>script.php</filename>
        <folder>css</folder>
        <folder>js</folder>
        <folder>images</folder>
        <folder>fonts</folder>
        <folder>html</folder>
        <folder>php</folder>
        <folder>partial</folder>
        <folder>language</folder>
        <folder>media</folder>
    </files>

    <media destination="templates/site/wmarka" folder="media">
        <folder>css</folder>
        <folder>js</folder>
        <folder>images</folder>
        <folder>fonts</folder>
        <filename>joomla.asset.json</filename>
    </media>

    <positions>
        <position>toolbar</position>
        <position>headbar</position>
        <position>logo</position>
        <position>head-banner</position>
        <position>navbar-left</position>
        <position>navbar-center</position>
        <position>navbar-right</position>
        <position>iconnav</position>
        <position>lang</position>
        <position>offcanvas-menu</position>
        <position>offcanvas</position>
        
        <position>breadcrumb</position>
        <position>adver-top</position>
        <position>slider</position>
        
        <position>block-a</position>
        <position>block-b</position>
        <position>block-c</position>
        <position>block-d</position>
        <position>block-e</position>
        <position>block-f</position>
        <position>block-g</position>
        <position>block-h</position>
        <position>block-i</position>
        <position>block-k</position>
        
        <position>footer-left</position>
        <position>footer-center</position>
        <position>footer-right</position>
        <position>counters</position>
        <position>debug</position>
    </positions>

    <languages folder="language">
        <language tag="ru-RU">ru-RU/tpl_wmarka.ini</language>
        <language tag="ru-RU">ru-RU/tpl_wmarka.sys.ini</language>
        <language tag="en-GB">en-GB/tpl_wmarka.ini</language>
        <language tag="en-GB">en-GB/tpl_wmarka.sys.ini</language>
    </languages>

    <config>
        <fields name="params">
            <fieldset name="basic" label="TPL_WMARKA_BASIC_SETTINGS">
                <field name="copyright_text" type="text" label="TPL_WMARKA_COPYRIGHT_LABEL" default="Webmarka Kazakhstan" />
            </fieldset>
        </fields>
    </config>
</extension>
